{
  "manifest_version": 3,
  "name": "GeraPrint Twitter",
  "version": "3.0",
  "permissions": ["storage", "activeTab", "scripting"],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://twitter.com/*", "https://x.com/*"],
      "js": ["content.js"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["generator.html"],
      "matches": ["<all_urls>"]
    }
  ]
}