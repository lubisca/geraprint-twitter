{
  "manifest_version": 3,
  "name": "InstaCleaner Pro",
  "version": "2.1",
  "permissions": ["storage", "activeTab"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://twitter.com/*", "https://x.com/*"],
      "js": ["content.js"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["generator.html"],
      "matches": ["<all_urls>"]
    }
  ]
}